---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  image?: string;
}

const {
  title,
  description,
  image = "/images/previews/paintings/akvarel/i-was-18.webp",
} = Astro.props;

const pageTitle =
  title === "Morten Muusmann" ? title : `${title} | Morten Muusmann`;
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : Astro.url;
const socialImage = Astro.site ? new URL(image, Astro.site) : image;
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/images/brand/mm-logo.svg" type="image/svg+xml" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="da_DK" />
    <meta property="og:site_name" content="Morten Muusmann" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Gå til indhold</a>
    <Header currentPath={Astro.url.pathname} />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
