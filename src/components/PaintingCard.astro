---
import { previewImageFor, type Painting } from "../data/paintings";

interface Props {
  painting: Painting;
  index: number;
  eager?: boolean;
}

const { painting, index, eager = false } = Astro.props;
const previewImage = previewImageFor(painting.image);
---

<article class="painting-card" id={painting.id}>
  <a
    class="painting-card__image"
    href={painting.image}
    data-lightbox-trigger
    data-lightbox-index={index}
    data-title={painting.title}
    data-technique={painting.technique}
    data-size={painting.size ?? ""}
    data-width={painting.width}
    data-height={painting.height}
    aria-haspopup="dialog"
    aria-label={`Vis ${painting.title} i billedvisning`}
  >
    <img
      src={previewImage}
      alt={painting.title}
      width={painting.width}
      height={painting.height}
      loading={eager ? "eager" : "lazy"}
      fetchpriority={eager ? "high" : "auto"}
      decoding="async"
    />
  </a>
  <div class="painting-card__meta">
    <h2>{painting.title}</h2>
    <p>
      <span>{painting.technique}</span>
      {painting.size && <span aria-hidden="true">·</span>}
      {painting.size && <span>{painting.size}</span>}
    </p>
  </div>
</article>
