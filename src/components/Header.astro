---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navigation = [
  { href: "/", label: "Forside" },
  { href: "/biografi", label: "Biografi" },
  { href: "/malerier", label: "Malerier" },
  { href: "/kontakt", label: "Kontakt" },
];

const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="brand" href="/" aria-label="Morten Muusmann – forside">
      <span class="brand__mark">
        <img src="/images/brand/mm-logo.svg" alt="" width="32" height="42" />
      </span>
      <span class="brand__text">
        <strong>Morten Muusmann</strong>
        <small>Kunstmaler</small>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="Primær navigation">
      {
        navigation.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <details class="mobile-nav">
      <summary>
        <span class="visually-hidden">Åbn navigation</span>
        <span class="mobile-nav__icon" aria-hidden="true">
          <i></i>
          <i></i>
          <i></i>
        </span>
      </summary>
      <nav aria-label="Mobil navigation">
        {
          navigation.map((item) => (
            <a
              href={item.href}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </details>
  </div>
</header>
