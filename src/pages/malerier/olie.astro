---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PaintingGrid from "../../components/PaintingGrid.astro";
import CategoryNav from "../../components/CategoryNav.astro";
import {
  categoryInfo,
  paintingsByCategory,
} from "../../data/paintings";

const category = categoryInfo.olie;
const categoryPaintings = paintingsByCategory("olie");
---

<BaseLayout
  title="Olie"
  description="Se Morten Muusmanns oliemalerier med dybe lag, tekstur og intense farver."
  image="/images/previews/paintings/olie/eye-out.webp"
>
  <section class="page-intro shell">
    <p class="eyebrow">Malerier · {categoryPaintings.length} værker</p>
    <h1>{category.heading}</h1>
    <p>{category.description}</p>
    <CategoryNav current="olie" />
  </section>

  <section class="gallery-section shell">
    <PaintingGrid paintings={categoryPaintings} eagerCount={3} />
  </section>

  <figure class="quote shell">
    <blockquote>“{category.quote}”</blockquote>
    <figcaption>{category.quoteAuthor}</figcaption>
  </figure>
</BaseLayout>
