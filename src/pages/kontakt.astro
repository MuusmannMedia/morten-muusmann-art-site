---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Kontakt"
  description="Kontakt Morten Muusmann om malerier, værker og kunstnerisk arbejde."
>
  <section class="contact-page shell">
    <div class="contact-page__intro">
      <p class="eyebrow">Kontakt</p>
      <h1>Har du lyst til at vide mere om mine billeder?</h1>
      <p>
        Du er velkommen til at skrive, hvis du har spørgsmål til et værk eller
        ønsker at høre mere om mit arbejde.
      </p>
    </div>

    <div class="contact-card">
      <div>
        <p class="contact-card__label">E-mail</p>
        <a href="mailto:morten.muusmann@gmail.com">
          morten.muusmann@gmail.com
        </a>
      </div>
      <div>
        <p class="contact-card__label">Instagram</p>
        <a href="https://instagram.com/themuzz/" target="_blank" rel="noreferrer">
          @themuzz
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
